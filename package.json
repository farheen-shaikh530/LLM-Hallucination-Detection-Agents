    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "string-similarity": "^4.0.4",
    "vite": "^5.4.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
