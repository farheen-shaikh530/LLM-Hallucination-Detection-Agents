PORT=3001
NODE_ENV=development
API_BASE_URL=https://releasetrain.io/api

# ── NVIDIA NIM ──────────────────────────────────────────────────────────────
# Free API key at https://build.nvidia.com
# Required for: NeMo Guardrails (Gate 1), NeMo Reranker, NIM embedding fallback
# Leave blank to run in offline/regex-only mode (all NVIDIA features disabled)
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE

# ── NeMo Guardrails (Gate 1 topic classifier) ───────────────────────────────
# LLM used to classify whether a query is about software/OS updates.
# Any NVIDIA NIM chat model works. Lighter = faster Gate 1 latency.
GUARDRAILS_MODEL=meta/llama-3.1-8b-instruct
LLM_RESPONSE_MODEL=meta/llama-3.1-70b-instruct

# ── Triton Inference Server (local embedding server) ────────────────────────
# Point to a running Triton instance to use local GPU inference for embeddings.
# Falls back to NVIDIA NIM cloud if Triton is unreachable.
TRITON_URL=http://localhost:8000
TRITON_MODEL=nv-embedqa-e5-v5
